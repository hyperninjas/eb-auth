# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Comma-separated list of allowed CORS origins.
# Example for multiple: https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:5173

# ── Better Auth ────────────────────────────────────────────────────────────
# MUST be at least 32 random characters. Generate with:
#   openssl rand -base64 48
BETTER_AUTH_SECRET=replace-with-a-32-plus-character-random-string-please
BETTER_AUTH_URL=http://localhost:3000

# ── Postgres ───────────────────────────────────────────────────────────────
# In production, point this at PgBouncer (not Postgres directly) so the
# per-pod connection pool doesn't exhaust max_connections under load.
DATABASE_URL=postgresql://eb_auth:eb_auth@localhost:5432/eb_auth

# Per-pod Prisma connection pool size. Total cluster connections =
# DB_POOL_MAX × replicas — keep this small (5–10) for production.
DB_POOL_MAX=10

# ── Redis ──────────────────────────────────────────────────────────────────
# Required: rate-limit store + Better Auth session secondary cache.
# In production use a managed Redis (Upstash, ElastiCache, etc.).
REDIS_URL=redis://localhost:6379

# ── OAuth providers ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Observability ──────────────────────────────────────────────────────────
# Optional pino log level override. Defaults: debug (dev) / info (prod).
# LOG_LEVEL=debug

# ── HTTP / proxy ───────────────────────────────────────────────────────────
# Number of reverse proxy hops to trust. 1 behind a single LB; higher when
# Cloudflare → ALB → app, etc.
TRUST_PROXY=1

# Outbound HTTP timeout for OAuth provider calls (ms).
OUTBOUND_HTTP_TIMEOUT_MS=5000

# Hard cap on graceful shutdown duration (ms) before force-exit.
SHUTDOWN_TIMEOUT_MS=15000

EPC_ENABLED=true
EPC_API_EMAIL=polash@technext.it
EPC_API_KEY=48a0c9dc38e9612c8d7efcac5388b0bab188fcfc

# ── Solar Forecast ─────────────────────────────────────────────────────────
SOLAR_ENABLED=true
SOLAR_API_BASE_URL=https://open.quartz.solar
SOLAR_HTTP_TIMEOUT_MS=15000
SOLAR_CACHE_TTL_SECONDS=21600

# ── Weather Forecast ───────────────────────────────────────────────────────
WEATHER_ENABLED=true
WEATHER_API_BASE_URL=https://api.open-meteo.com
WEATHER_HTTP_TIMEOUT_MS=10000
WEATHER_CACHE_TTL_SECONDS=21600
