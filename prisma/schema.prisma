// Prisma schema for eb-auth.
//
// This schema mirrors the tables Better Auth's CLI generated previously,
// plus the application's own `device` table. After editing or first install
// run:
//
//   pnpm prisma generate
//   pnpm prisma db pull --print   # to diff against the live DB (no write)
//   pnpm prisma migrate dev       # to author future migrations
//
// Snake_case column/table names are preserved via @map / @@map so the
// existing database does not need to be rewritten.

// Prisma 7 generator. The new `prisma-client` provider replaces
// `prisma-client-js`; output is required and the runtime no longer ships
// the Rust query engine — connections go through @prisma/adapter-pg.
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Zod schemas auto-generated from this Prisma schema. Single source of
// truth for shapes — every Zod schema in `src/modules/<m>/<m>.dto.ts` and
// `src/modules/<m>/<m>.schema.ts` is built by Pick/Omit/extend on top of
// these generated schemas. Rename a column here → typecheck flags every
// downstream usage.
generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/generated/zod"
}

// Datasource provider only — the connection string lives in
// `prisma.config.ts` (Prisma 7 moved it out of the schema).
datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Better Auth — core
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @db.Timestamptz(3)
  updatedAt     DateTime @db.Timestamptz(3)

  // admin plugin
  role       String?
  banned     Boolean?
  banReason  String?
  banExpires DateTime? @db.Timestamptz(3)

  // twoFactor plugin
  twoFactorEnabled Boolean?

  // additionalFields (configured in modules/auth/auth.ts)
  isOnboardingDone Boolean @default(false)
  onboardingStatus String  @default("pending")
  location         String?
  postcode         String?
  homeName         String?
  houseId          String?
  attributes       Json?

  sessions    Session[]
  accounts    Account[]
  twoFactors  TwoFactor[]
  members     Member[]
  invitations Invitation[]

  // Owned by the OPTIONAL shop integration module. If you remove
  // src/modules/shop/, drop this relation and the UserCommerceProfile
  // model below in the same migration. Nothing in core depends on it.
  commerceProfile UserCommerceProfile?

  // Owned by the OPTIONAL energy-profile module. If you remove
  // src/modules/energy-profile/, drop this relation and the
  // PropertyProfile model in the same migration.
  propertyProfile PropertyProfile?

  @@index([houseId])
  @@index([isOnboardingDone])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @db.Timestamptz(3)
  token     String   @unique
  createdAt DateTime @db.Timestamptz(3)
  updatedAt DateTime @db.Timestamptz(3)
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // organization plugin
  activeOrganizationId String?

  // admin plugin
  impersonatedBy String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(3)
  scope                 String?
  password              String?
  createdAt             DateTime  @db.Timestamptz(3)
  updatedAt             DateTime  @db.Timestamptz(3)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @db.Timestamptz(3)
  createdAt  DateTime? @db.Timestamptz(3)
  updatedAt  DateTime? @db.Timestamptz(3)

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────────────────
// Better Auth — jwt plugin
// ─────────────────────────────────────────────────────────────────────────────

model Jwks {
  id         String   @id
  publicKey  String
  privateKey String
  createdAt  DateTime @db.Timestamptz(3)

  @@map("jwks")
}

// ─────────────────────────────────────────────────────────────────────────────
// Better Auth — twoFactor plugin
// ─────────────────────────────────────────────────────────────────────────────

model TwoFactor {
  id          String @id
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("twoFactor")
}

// ─────────────────────────────────────────────────────────────────────────────
// Better Auth — organization plugin
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id
  name      String
  slug      String?  @unique
  logo      String?
  createdAt DateTime @db.Timestamptz(3)
  metadata  String?

  members     Member[]
  invitations Invitation[]

  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @db.Timestamptz(3)

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime     @db.Timestamptz(3)
  inviterId      String
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ─────────────────────────────────────────────────────────────────────────────
// Optional integration — shop (Medusa)
//
// Owned by the detachable `src/modules/shop/` integration. Holds the
// 1:1 mapping between a Better Auth user and the corresponding Medusa
// `customer.id`. Better Auth remains the source of truth for identity;
// this table just remembers which Medusa customer record belongs to
// which of our users so we can attach them to carts server-side.
//
// To remove the shop integration entirely:
//   1. Delete src/modules/shop/
//   2. Remove the `commerceProfile` relation from the User model above
//   3. Delete this model
//   4. `pnpm prisma migrate dev --name drop_shop_integration`
// ─────────────────────────────────────────────────────────────────────────────

model UserCommerceProfile {
  userId           String   @id @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  medusaCustomerId String   @unique @map("medusa_customer_id") @db.VarChar(64)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("user_commerce_profile")
}

// ─────────────────────────────────────────────────────────────────────────────
// Optional module — energy-profile
//
// Owned by the detachable `src/modules/energy-profile/` module. Stores
// per-user EPC data, hardware extrapolation results, tariff information,
// and user energy consumption profiles for the "Best Guess" onboarding
// engine.
//
// To remove the energy-profile module entirely:
//   1. Delete src/modules/energy-profile/
//   2. Remove the `propertyProfile` relation from the User model above
//   3. Delete these 6 models
//   4. `pnpm prisma migrate dev --name drop_energy_profile`
// ─────────────────────────────────────────────────────────────────────────────

model PropertyProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core EPC identifiers — persisted so we don't re-fetch on every request
  uprn           String?  @db.VarChar(20)
  lmkKey         String   @map("lmk_key") @db.VarChar(100)
  address        String   @db.VarChar(500)
  postcode       String   @db.VarChar(10)
  propertyType   String   @map("property_type") @db.VarChar(50)
  builtForm      String   @map("built_form") @db.VarChar(50)
  totalFloorArea Float    @map("total_floor_area")

  // Full latest EPC certificate snapshot (60+ fields as JSON)
  latestEpcData  Json     @map("latest_epc_data")

  // Derived hardware extrapolation result (recalculated on refresh)
  hardware       Json?

  // Whether the user has confirmed/corrected the best-guess results
  userVerified   Boolean  @default(false) @map("user_verified")

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  history        PropertyEpcHistory[]
  loadProfile    UserLoadProfile?

  @@index([postcode])
  @@index([uprn])
  @@map("property_profile")
}

model PropertyEpcHistory {
  id                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId                String          @map("profile_id") @db.Uuid
  profile                  PropertyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  lmkKey                   String          @map("lmk_key") @db.VarChar(100)
  inspectionDate           DateTime        @map("inspection_date") @db.Date
  lodgementDate            DateTime        @map("lodgement_date") @db.Date

  // Key fields for the UPRN "Time Machine" analysis
  mainheatDescription      String?         @map("mainheat_description")
  photoSupply              String?         @map("photo_supply") @db.VarChar(20)
  spaceHeatingDemand       Float?          @map("space_heating_demand")
  energyConsumptionCurrent Float?          @map("energy_consumption_current")

  // Full certificate snapshot
  certificateData          Json            @map("certificate_data")

  @@unique([profileId, lmkKey])
  @@index([profileId, inspectionDate(sort: Asc)])
  @@map("property_epc_history")
}

model EnergyProvider {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String  @unique @db.VarChar(100)
  slug     String  @unique @db.VarChar(100)
  isActive Boolean @default(true) @map("is_active")

  tariffs      EnergyTariff[]
  loadProfiles UserLoadProfile[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("energy_provider")
}

model EnergyTariff {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String         @map("provider_id") @db.Uuid
  provider   EnergyProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name       String         @db.VarChar(200)
  // "flat" = standard variable / fixed, "tou" = time-of-use, "export" = SEG export
  tariffType String         @map("tariff_type") @db.VarChar(20)

  // Rates stored as integer pence (× 100) to avoid float rounding.
  // e.g. 24.50p/kWh → 2450. Divide by 100 in the application layer.
  flatRatePence       Int? @map("flat_rate_pence")
  peakRatePence       Int? @map("peak_rate_pence")
  offPeakRatePence    Int? @map("off_peak_rate_pence")
  peakStartHour       Int? @map("peak_start_hour")
  peakEndHour         Int? @map("peak_end_hour")
  standingChargePence Int  @map("standing_charge_pence")
  segExportRatePence  Int? @map("seg_export_rate_pence")

  isDefault Boolean   @default(false) @map("is_default")
  validFrom DateTime  @map("valid_from") @db.Date
  validTo   DateTime? @map("valid_to") @db.Date
  // "octopus_api" | "ofgem_svt" | "manual"
  source    String    @db.VarChar(50)

  loadProfiles UserLoadProfile[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([providerId, name, validFrom])
  @@index([providerId])
  @@index([tariffType])
  @@map("energy_tariff")
}

model UserLoadProfile {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId  String          @unique @map("profile_id") @db.Uuid
  profile    PropertyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  providerId String         @map("provider_id") @db.Uuid
  tariffId   String         @map("tariff_id") @db.Uuid
  provider   EnergyProvider @relation(fields: [providerId], references: [id])
  tariff     EnergyTariff   @relation(fields: [tariffId], references: [id])

  // Stored as pence to avoid float rounding
  monthlyBillPence Int   @map("monthly_bill_pence")
  dailyKwh         Float @map("daily_kwh")

  // 24-element array: hourly kWh distribution (standard UK residential curve)
  hourlyDistribution Json @map("hourly_distribution")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("user_load_profile")
}

model PvgisIrradiance {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  latitude  Float
  longitude Float

  // 12-element array: monthly average daily global irradiation (kWh/m2/day)
  monthlyIrradiance    Json  @map("monthly_irradiance")
  optimalAngle         Float? @map("optimal_angle")
  annualYieldKwhPerKwp Float @map("annual_yield_kwh_per_kwp")

  fetchedAt DateTime @default(now()) @map("fetched_at") @db.Timestamptz()

  @@unique([latitude, longitude])
  @@map("pvgis_irradiance")
}

// ─────────────────────────────────────────────────────────────────────────────
// Application — devices
// ─────────────────────────────────────────────────────────────────────────────

model Device {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId   String   @unique @map("device_id") @db.VarChar(100)
  rfid       String   @unique @db.VarChar(100)
  macAddress String   @unique @map("mac_address") @db.VarChar(17)
  name       String?  @db.VarChar(200)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  createdBy  String   @map("created_by") @db.VarChar(64)

  @@index([createdAt(sort: Desc)])
  @@map("device")
}
