# Medusa v2 environment variables — copy to `.env` and fill in.
#
# These are CONSUMED by `medusa-config.ts` via `loadEnv()`. The actual
# values for local dev are also passed in via docker-compose.yml so
# you usually don't need a separate `.env` file unless you're running
# `medusa develop` outside the container.

NODE_ENV=development

# Postgres + Redis — point at the SHARED instances the parent service
# uses. Different database name (`medusa`) and Redis logical DB (`/1`)
# preserve isolation.
DATABASE_URL=postgresql://eb_auth:eb_auth@postgres:5432/medusa
REDIS_URL=redis://redis:6379/1

# Secrets — generate new ones for any non-local environment with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-in-prod-32-bytes-min
COOKIE_SECRET=replace-me-in-prod-32-bytes-min

# CORS allow-lists.
#
# STORE_CORS is intentionally empty: the eb-auth /api/shop/* proxy is
# the ONLY caller into the store API, and it's a server-to-server call
# from inside the docker network — no browser ever hits the store
# routes directly, so no origin needs to be allow-listed.
#
# ADMIN_CORS / AUTH_CORS allow the local admin dashboard at
# http://localhost:9000 (Medusa serves it from the same port).
STORE_CORS=
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000
